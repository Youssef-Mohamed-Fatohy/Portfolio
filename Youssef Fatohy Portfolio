<style>
  :root { --bg-color: #F5F5DC; } /* Beige */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; font-family: 'Inter', sans-serif; }
  body { background: var(--bg-color); color: #3d2616; } /* Dark brown/grey for readable text */

  /* Ambient background */
  .ambient-glow {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: -50;
    background: radial-gradient(circle at 50% 0%, #FFFFFF 0%, #F5F5DC 60%);
  }

  /* Grid background */
  .grid-bg {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    pointer-events: none; z-index: -40; opacity: 0.8;
    background-image:
      linear-gradient(rgba(139,69,19,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(139,69,19,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at 50% 30%, black 20%, transparent 70%);
  }

  /* Text gradient (Brown to Teal) */
  .text-gradient {
    background: linear-gradient(to right, #8B4513, #0F766E);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Glass card */
  .glass-card {
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(194, 178, 128, 0.4); /* #C2B280 */
    backdrop-filter: blur(24px);
    transition: all 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
  }
  .glass-card:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(139, 69, 19, 0.2); /* #8B4513 */
    transform: translateY(-2px);
    box-shadow: 0 20px 40px -10px rgba(139, 69, 19, 0.1);
  }

  /* Skill pill */
  .skill-pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 14px; border-radius: 9999px; font-size: 11px;
    font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em;
    border: 1px solid rgba(194, 178, 128, 0.6);
    background: #FFFFFF;
    color: #8B4513; transition: all 0.3s ease;
  }
  .skill-pill:hover {
    border-color: #0F766E; color: #FFFFFF;
    background: #0F766E;
  }

  /* Timeline */
  .timeline-line {
    position: absolute; left: 15px; top: 32px; bottom: 0;
    width: 1px; background: rgba(194, 178, 128, 0.5);
  }
  .timeline-dot {
    position: absolute; left: 9px; top: 6px;
    width: 13px; height: 13px; border-radius: 50%;
    border: 2px solid #C2B280;
    background: #F5F5DC; z-index: 2;
  }
  .timeline-dot.active {
    border-color: #0F766E;
    box-shadow: 0 0 12px rgba(15, 118, 110, 0.3);
    background: rgba(15, 118, 110, 0.1);
  }

  /* Fade-in animation */
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease-out, transform 0.8s ease-out; }
  .reveal.active { opacity: 1; transform: translateY(0); }
  .delay-100 { transition-delay: 100ms; }
  .delay-200 { transition-delay: 200ms; }
  .delay-300 { transition-delay: 300ms; }
  .delay-400 { transition-delay: 400ms; }
  .delay-500 { transition-delay: 500ms; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #F5F5DC; }
  ::-webkit-scrollbar-thumb { background: #C2B280; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #8B4513; }

  /* Tag */
  .tag {
    font-size: 10px; font-weight: 500; text-transform: uppercase;
    letter-spacing: 0.1em; padding: 3px 10px; border-radius: 4px;
    background: rgba(15, 118, 110, 0.1); color: #0F766E;
    border: 1px solid rgba(15, 118, 110, 0.2);
  }
  .tag-green {
    background: rgba(15, 118, 110, 0.1); color: #0F766E;
    border-color: rgba(15, 118, 110, 0.2);
  }
  .tag-amber {
    background: #FFF3E0; color: #E65100;
    border-color: #FFE0B2;
  }

  /* Print button */
  .print-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; border-radius: 9999px; font-size: 11px;
    font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;
    background: #8B4513; color: #fff; border: none; cursor: pointer;
    transition: all 0.5s ease;
    box-shadow: 0 4px 10px rgba(139, 69, 19, 0.2);
  }
  .print-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 15px rgba(139, 69, 19, 0.3);
  }

  /* Project link */
  .project-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 500; color: #0F766E;
    text-decoration: none; transition: all 0.3s ease;
  }
  .project-link:hover { color: #094d48; gap: 10px; }

  /* KPI box */
  .kpi-box {
    text-align: center; padding: 16px 12px;
    border-radius: 12px;
    background: rgba(255,255,255,0.7);
    border: 1px solid rgba(194, 178, 128, 0.4);
  }
  .kpi-value {
    font-size: 22px; font-weight: 600; color: #8B4513;
    font-variant-numeric: tabular-nums;
  }
  .kpi-label {
    font-size: 10px; font-weight: 500; text-transform: uppercase;
    letter-spacing: 0.08em; color: #6b5a4e; margin-top: 4px;
  }

  /* ==================== PRINT STYLES ==================== */
  @media print {
    @page { margin: 1.5cm; size: A4; }
    body { background: #fff !important; color: #18181b !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    .ambient-glow, .grid-bg, .print-hide, .no-print { display: none !important; }
    .text-gradient { -webkit-text-fill-color: #18181b !important; }
    .glass-card {
      background: #f9fafb !important; border-color: #e4e4e7 !important;
      backdrop-filter: none !important; box-shadow: none !important;
      transform: none !important; break-inside: avoid;
    }
    .glass-card:hover { transform: none !important; box-shadow: none !important; }
    .skill-pill {
      background: #f4f4f5 !important; color: #3f3f46 !important;
      border-color: #d4d4d8 !important;
    }
    .skill-pill:hover { background: #f4f4f5 !important; color: #3f3f46 !important; }
    .timeline-line { background: #d4d4d8 !important; }
    .timeline-dot { border-color: #a1a1aa !important; background: #fff !important; }
    .timeline-dot.active { border-color: #3b82f6 !important; background: #eff6ff !important; box-shadow: none !important; }
    .tag { background: #eff6ff !important; color: #2563eb !important; border-color: #bfdbfe !important; }
    .tag-green { background: #f0fdf4 !important; color: #16a34a !important; border-color: #bbf7d0 !important; }
    .tag-amber { background: #fffbeb !important; color: #d97706 !important; border-color: #fde68a !important; }
    .kpi-box { background: #f9fafb !important; border-color: #e4e4e7 !important; }
    .kpi-value { color: #18181b !important; }
    .kpi-label { color: #71717a !important; }
    .project-link { color: #2563eb !important; }
    .reveal { opacity: 1 !important; transform: none !important; }
    section { break-inside: avoid; }
    .print-header-bar { background: #18181b !important; color: #fff !important; padding: 24px 0 !important; margin-bottom: 24px !important; }
    .print-header-bar * { color: #fff !important; }
  }
